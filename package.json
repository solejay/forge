{
  "name": "forge",
  "version": "0.1.0",
  "private": true,
  "description": "Forge pi agentic harness packages: core orchestration, design studio, and mobile development.",
  "keywords": ["pi-package", "agent-harness", "forge", "mobile", "design"],
  "license": "MIT",
  "scripts": {
    "smoke": "bash scripts/smoke-test.sh",
    "doctor": "pi -p --no-session --no-extensions -e . \"Run forge_doctor and summarize the Forge health report.\""
  },
  "pi": {
    "extensions": [
      "./packages/forge-core/extensions/forge-core",
      "./packages/forge-design-studio/extensions/design-pipeline",
      "./packages/forge-mobile-dev/extensions/forge-mobile"
    ],
    "skills": [
      "./packages/forge-core/skills",
      "./packages/forge-design-studio/skills",
      "./packages/forge-mobile-dev/skills"
    ]
  },
  "workspaces": [
    "packages/*"
  ]
}
